# .env.example — copy to .env and fill in values
# NEVER commit .env to version control

# API security
EDGE_AI_API_KEY=<generate with: openssl rand -hex 32>

# Logging
EDGE_AI_LOG_LEVEL=INFO

# Inference device: hailo | cpu | auto
EDGE_AI_INFERENCE_DEVICE=auto

# Camera
EDGE_AI_CAMERA_FPS=30
EDGE_AI_CAMERA_WIDTH=1280
EDGE_AI_CAMERA_HEIGHT=720

# LiDAR serial port
EDGE_AI_LIDAR_PORT=/dev/ttyACM0

# MQTT (optional)
EDGE_AI_MQTT_PASSWORD=

# Dashboard port
DASHBOARD_PORT=8080
